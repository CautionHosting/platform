# mv env.example .env

# AWS Configuration (required)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_ACCOUNT_ID=
AWS_REGION=us-west-2
TERRAFORM_STATE_BUCKET=

# AWS Configuration (optional - have defaults)
# EIF_S3_BUCKET=
# SSH_KEY_NAME=

# Service URLs
API_SERVICE_URL=http://api:8080
EMAIL_SERVICE_URL=http://email:8082
FRONTEND_URL=http://localhost:3000
GIT_HOSTNAME=localhost:2222
VITE_PROXY_TARGET=http://gateway:8080

# Gateway Configuration
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/caution
DB_MAX_CONNECTIONS=25
SSH_PORT=2222
SSH_HOST_KEY_PATH=/etc/ssh/ssh_host_ed25519_key
FRONTEND_DIR=/app/frontend

# WebAuthn Configuration
RP_ID=localhost
RP_DISPLAY_NAME=Caution
RP_ORIGINS=http://localhost:8000,http://localhost:8080,http://localhost:3000
SESSION_TIMEOUT_HOURS=24

# Internal Service Authentication (required for production)
# Shared secret between gateway and API for internal service-to-service auth
# Generate with: openssl rand -base64 32
INTERNAL_SERVICE_SECRET=

# Email Service Configuration
EMAIL_TEST_MODE=true
SMTP_HOST=smtp.migadu.com
SMTP_PORT=587
SMTP_USERNAME=your-email@yourdomain.com
SMTP_PASSWORD=your-smtp-password
FROM_EMAIL=noreply@yourdomain.com
FROM_NAME=Caution

# Enclave Configuration (optional)
CAUTION_ENCLAVE_SOURCE=
CAUTION_ENCLAVE_VERSION=

# Enclave dependency pins (optional - have defaults)
ENCLAVEOS_COMMIT=9582e25239430070667fdd0a6b64d887f1c308df
BOOTPROOF_COMMIT=64dae0628e58b9f898b89f9b7a404b37e2f0ca9f
STEVE_COMMIT=ed38a190cd5d7a8f452c854e41d00ec748e172bf

# Data Directory (optional - defaults to /var/cache/caution/ in containers)
# For local dev, set to a local path like ./caution-data
CAUTION_DATA_DIR=

# Cloud Credentials Encryption (required for managed on-prem deployments)
# Generate with: openssl rand -base64 32
CAUTION_ENCRYPTION_KEY=

# Paddle Billing (optional - required for payment collection)
# Get these from https://sandbox-vendors.paddle.com/ (sandbox) or https://vendors.paddle.com/ (production)
PADDLE_API_URL=https://sandbox-api.paddle.com
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
PADDLE_CLIENT_TOKEN=
# Create a product + price in Paddle dashboard; use the price ID here
PADDLE_SETUP_PRICE_ID=
# Frontend: set to 'true' for sandbox, 'false' for production
VITE_PADDLE_SANDBOX=true

# Dedicated Builder (optional - builds EIFs on ephemeral EC2 instances)
BUILDER_ENABLED=false
BUILDER_AMI_ID=
BUILDER_SECURITY_GROUP_ID=
BUILDER_SUBNET_ID=
BUILDER_INSTANCE_PROFILE=
BUILDER_TIMEOUT_SECS=1200

# Metering Configuration
METERING_SERVICE_URL=http://metering:8083
METERING_INTERVAL_SECS=60
