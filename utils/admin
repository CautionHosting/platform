cmd_list_orgs() {
    echo "=== Organizations ==="
    psql_pretty -c "
        SELECT
            o.id,
            o.name,
            o.is_active,
            (SELECT COUNT(*) FROM organization_members WHERE organization_id = o.id) as members,
            (SELECT COUNT(*) FROM compute_resources WHERE organization_id = o.id) as apps,
            o.created_at::date as created
        FROM organizations o
        ORDER BY o.created_at DESC;
    "
}

cmd_show_org() {
    local org_id="$1"
    validate_uuid "$org_id"

    echo "=== Organization ==="
    psql_pretty -c "
        SELECT id, name, is_active, created_at, updated_at
        FROM organizations WHERE id = '$org_id';
    "

    echo ""
    echo "=== Members ==="
    psql_pretty -c "
        SELECT u.id, u.username, u.email, om.role, om.created_at as joined
        FROM organization_members om
        JOIN users u ON u.id = om.user_id
        WHERE om.organization_id = '$org_id'
        ORDER BY om.role, u.username;
    "

    echo ""
    echo "=== Apps/Resources ==="
    psql_pretty -c "
        SELECT id, resource_name, state, region, public_ip, created_at
        FROM compute_resources
        WHERE organization_id = '$org_id'
        ORDER BY created_at DESC;
    "
}

cmd_list_users() {
    echo "=== Users ==="
    psql_pretty -c "
        SELECT
            u.id,
            u.username,
            u.email,
            (SELECT COUNT(*) FROM organization_members WHERE user_id = u.id) as orgs,
            (SELECT COUNT(*) FROM ssh_keys WHERE user_id = u.id) as ssh_keys,
            u.created_at::date as created
        FROM users u
        ORDER BY u.created_at DESC;
    "
}

cmd_show_user() {
    local user_id="$1"
    validate_uuid "$user_id"

    echo "=== User ==="
    psql_pretty -c "
        SELECT id, username, email, is_active, created_at, updated_at
        FROM users WHERE id = '$user_id';
    "

    echo ""
    echo "=== Organizations ==="
    psql_pretty -c "
        SELECT o.id, o.name, om.role, om.created_at as joined
        FROM organization_members om
        JOIN organizations o ON o.id = om.organization_id
        WHERE om.user_id = '$user_id'
        ORDER BY om.created_at;
    "

    echo ""
    echo "=== SSH Keys ==="
    psql_pretty -c "
        SELECT fingerprint, key_type, name, created_at
        FROM ssh_keys
        WHERE user_id = '$user_id'
        ORDER BY created_at;
    "

    echo ""
    echo "=== FIDO2 Credentials ==="
    psql_pretty -c "
        SELECT id, encode(credential_id, 'hex') as credential_id, sign_count, created_at
        FROM fido2_credentials
        WHERE user_id = '$user_id'
        ORDER BY created_at;
    "
}

cmd_list_apps() {
    echo "=== Apps/Compute Resources ==="
    psql_pretty -c "
        SELECT
            cr.id,
            cr.resource_name,
            cr.state,
            cr.region,
            cr.public_ip,
            o.name as org,
            cr.created_at::date as created
        FROM compute_resources cr
        JOIN organizations o ON o.id = cr.organization_id
        ORDER BY cr.created_at DESC
        LIMIT 50;
    "
}

cmd_show_app() {
    local app_id="$1"
    validate_uuid "$app_id"

    echo "=== App/Compute Resource ==="
    psql_pretty -c "
        SELECT
            cr.id,
            cr.resource_name,
            cr.state,
            cr.region,
            cr.public_ip,
            cr.provider_resource_id as instance_id,
            cr.estimated_monthly_cost,
            o.name as organization,
            cr.configuration,
            cr.created_at,
            cr.updated_at,
            cr.deployed_at
        FROM compute_resources cr
        JOIN organizations o ON o.id = cr.organization_id
        WHERE cr.id = '$app_id';
    "
}

cmd_list_credentials() {
    echo "=== Cloud Credentials ==="
    psql_pretty -c "
        SELECT
            cc.id,
            cc.name,
            cc.platform,
            cc.is_default,
            o.name as org,
            cc.created_at::date as created
        FROM cloud_credentials cc
        JOIN organizations o ON o.id = cc.organization_id
        ORDER BY cc.created_at DESC;
    "
}

cmd_list_alpha_codes() {
    echo "=== Alpha/Beta Codes ==="
    psql_pretty -c "
        SELECT
            id,
            code,
            created_by,
            CASE WHEN used_at IS NOT NULL THEN 'used' ELSE 'available' END as status,
            used_at,
            expires_at,
            created_at::date as created
        FROM beta_codes
        ORDER BY created_at DESC;
    "
}

cmd_user_by_code() {
    local code="$1"

    echo "=== User by Alpha Code ==="
    psql_pretty -c "
        SELECT
            u.id,
            u.username,
            u.email,
            u.created_at,
            bc.code as alpha_code,
            bc.created_by as code_issued_by
        FROM users u
        JOIN beta_codes bc ON u.beta_code_id = bc.id
        WHERE bc.code = '$code';
    "
}

cmd_apps_by_user() {
    local user_id="$1"
    validate_uuid "$user_id"

    echo "=== Apps for User ==="
    psql_pretty -c "
        SELECT
            cr.id,
            cr.resource_name,
            cr.state,
            cr.region,
            cr.public_ip,
            o.name as org,
            cr.created_at
        FROM compute_resources cr
        JOIN organizations o ON o.id = cr.organization_id
        JOIN organization_members om ON om.organization_id = o.id
        WHERE om.user_id = '$user_id'
        ORDER BY cr.created_at DESC;
    "
}

cmd_list_legal_docs() {
    echo "=== Legal Documents ==="
    psql_pretty -c "
        SELECT
            id,
            document_type,
            version,
            is_active,
            requires_blocking_reacceptance as blocking,
            requires_acknowledgment as ack,
            effective_at::date as effective,
            source_path,
            left(source_commit_sha, 12) as commit,
            url
        FROM legal_documents
        ORDER BY document_type, effective_at DESC;
    "
}

cmd_add_legal_doc() {
    echo "Add new legal document version"
    echo ""

    read -rp "Document type (terms_of_service / privacy_notice): " doc_type
    if [[ "$doc_type" != "terms_of_service" && "$doc_type" != "privacy_notice" ]]; then
        echo "Error: document_type must be 'terms_of_service' or 'privacy_notice'"
        exit 1
    fi

    read -rp "Version (e.g. 2026-06-01): " version
    read -rp "URL: " url
    read -rp "Effective date (YYYY-MM-DD): " effective_at
    read -rp "Source path in caution/website (e.g. terms.md): " source_path
    read -rp "Source commit SHA: " source_commit_sha
    read -rp "Content SHA-256: " content_sha256
    read -rp "Requires blocking reacceptance? (y/n): " blocking
    read -rp "Requires acknowledgment? (y/n): " ack
    read -rp "Summary JSON (optional, press enter to skip): " summary

    local blocking_bool="false"
    [[ "$blocking" == "y" ]] && blocking_bool="true"
    local ack_bool="false"
    [[ "$ack" == "y" ]] && ack_bool="true"

    local summary_val="NULL"
    if [[ -n "$summary" ]]; then
        summary_val="'$summary'::jsonb"
    fi

    echo ""
    echo "Will insert:"
    echo "  type:       $doc_type"
    echo "  version:    $version"
    echo "  url:        $url"
    echo "  effective:  $effective_at"
    echo "  source:     $source_path @ $source_commit_sha"
    echo "  content:    $content_sha256"
    echo "  blocking:   $blocking_bool"
    echo "  ack:        $ack_bool"
    echo "  is_active:  false (use activate-legal-doc to activate)"
    echo ""
    read -rp "Confirm? (y/n): " confirm
    [[ "$confirm" != "y" ]] && { echo "Aborted."; exit 0; }

    psql_cmd -c "
        INSERT INTO legal_documents (document_type, version, url, effective_at,
            is_active, requires_blocking_reacceptance, requires_acknowledgment,
            source_path, source_commit_sha, content_sha256, summary_json)
        VALUES ('$doc_type', '$version', '$url', '$effective_at',
            false, $blocking_bool, $ack_bool,
            '$source_path', '$source_commit_sha', '$content_sha256', $summary_val);
    "
    echo "Document added (inactive). Use 'activate-legal-doc' to make it active."
}

cmd_activate_legal_doc() {
    local doc_id="$1"
    validate_uuid "$doc_id"

    # Show what we're about to activate
    echo "=== Document to activate ==="
    psql_pretty -c "
        SELECT id, document_type, version, is_active, effective_at::date
        FROM legal_documents WHERE id = '$doc_id';
    "

    local doc_type
    doc_type=$(psql_cmd -c "SELECT document_type FROM legal_documents WHERE id = '$doc_id';")
    if [[ -z "$doc_type" ]]; then
        echo "Error: Document not found"
        exit 1
    fi

    # Show currently active version of this type
    echo "=== Currently active $doc_type ==="
    psql_pretty -c "
        SELECT id, version, effective_at::date
        FROM legal_documents
        WHERE document_type = '$doc_type' AND is_active = true;
    "

    echo ""
    echo "This will deactivate the current active $doc_type and activate the new version."
    read -rp "Confirm? (y/n): " confirm
    [[ "$confirm" != "y" ]] && { echo "Aborted."; exit 0; }

    psql_cmd -c "
        BEGIN;
        UPDATE legal_documents SET is_active = false
            WHERE document_type = '$doc_type' AND is_active = true;
        UPDATE legal_documents SET is_active = true
            WHERE id = '$doc_id';
        COMMIT;
    "
    echo "Done. New active $doc_type version activated."
}

cmd_user_legal_status() {
    local user_id="$1"
    validate_uuid "$user_id"

    echo "=== User ==="
    psql_pretty -c "
        SELECT id, username, created_at::date as created
        FROM users WHERE id = '$user_id';
    "

    echo ""
    echo "=== Legal Events ==="
    psql_pretty -c "
        SELECT document_type, document_version, event_type, event_source,
               occurred_at, ip_address
        FROM user_legal_events
        WHERE user_id = '$user_id'
        ORDER BY occurred_at DESC;
    "

    echo ""
    echo "=== Current Status ==="
    psql_pretty -c "
        SELECT
            ld.document_type,
            ld.version as active_version,
            left(ld.source_commit_sha, 12) as active_commit,
            ule.document_version as user_version,
            ule.event_type as last_event,
            CASE
                WHEN ule.document_version IS NULL THEN 'no record'
                WHEN ule.legal_document_id = ld.id THEN 'current'
                ELSE 'outdated'
            END as status
        FROM legal_documents ld
        LEFT JOIN LATERAL (
            SELECT legal_document_id, document_version, event_type
            FROM user_legal_events
            WHERE user_id = '$user_id'
              AND document_type = ld.document_type
            ORDER BY occurred_at DESC
            LIMIT 1
        ) ule ON true
        WHERE ld.is_active = true
        ORDER BY ld.document_type;
    "
}

cmd_send_legal_notices() {
    local dry_run="true"
    local send_requested="false"
    local confirm_send="false"
    local api_url="${API_URL:-http://localhost:8080}"
    local doc_ids=()
    local recipient_ids=()
    local recipient_emails=()
    local limit=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --send)
                send_requested="true"
                dry_run="false"
                shift
                ;;
            --dry-run)
                send_requested="false"
                dry_run="true"
                shift
                ;;
            --confirm)
                confirm_send="true"
                shift
                ;;
            --api-url)
                api_url="${2:-}"
                shift 2
                ;;
            --recipient-id)
                validate_uuid "${2:-}"
                recipient_ids+=("${2:-}")
                shift 2
                ;;
            --recipient-email)
                validate_email_arg "${2:-}"
                recipient_emails+=("${2:-}")
                shift 2
                ;;
            --limit)
                validate_positive_integer "${2:-}"
                limit="${2:-}"
                shift 2
                ;;
            *)
                validate_uuid "$1"
                doc_ids+=("$1")
                shift
                ;;
        esac
    done

    if [[ -z "${INTERNAL_SERVICE_SECRET:-}" ]]; then
        echo "Error: INTERNAL_SERVICE_SECRET must be set"
        exit 1
    fi

    build_payload() {
        local payload_dry_run="$1"
        local payload="{\"dry_run\":$payload_dry_run}"

        if [[ ${#doc_ids[@]} -gt 0 ]]; then
            local ids_json=""
            local doc_id
            for doc_id in "${doc_ids[@]}"; do
                if [[ -n "$ids_json" ]]; then
                    ids_json+=","
                fi
                ids_json+="\"$doc_id\""
            done
            payload="${payload%\}}"
            payload+=",\"document_ids\":[$ids_json]}"
        fi

        if [[ ${#recipient_ids[@]} -gt 0 ]]; then
            local recipient_ids_json=""
            local recipient_id
            for recipient_id in "${recipient_ids[@]}"; do
                if [[ -n "$recipient_ids_json" ]]; then
                    recipient_ids_json+=","
                fi
                recipient_ids_json+="\"$recipient_id\""
            done
            payload="${payload%\}}"
            payload+=",\"recipient_ids\":[$recipient_ids_json]}"
        fi

        if [[ ${#recipient_emails[@]} -gt 0 ]]; then
            local recipient_emails_json=""
            local recipient_email
            for recipient_email in "${recipient_emails[@]}"; do
                if [[ -n "$recipient_emails_json" ]]; then
                    recipient_emails_json+=","
                fi
                recipient_emails_json+="\"$(json_escape "$recipient_email")\""
            done
            payload="${payload%\}}"
            payload+=",\"recipient_emails\":[$recipient_emails_json]}"
        fi

        if [[ -n "$limit" ]]; then
            payload="${payload%\}}"
            payload+=",\"limit\":$limit}"
        fi

        printf '%s' "$payload"
    }

    request_send() {
        local payload="$1"
        curl -sf \
            -H "Content-Type: application/json" \
            -H "x-internal-service-secret: $INTERNAL_SERVICE_SECRET" \
            -d "$payload" \
            "$api_url/internal/legal-notices/send"
    }

    print_response() {
        local response="$1"
        if command -v jq >/dev/null 2>&1; then
            echo "$response" | jq .
        else
            echo "$response"
        fi
    }

    if [[ "$send_requested" != "true" ]]; then
        echo "Dry-running legal notice email delivery..."
        print_response "$(request_send "$(build_payload "true")")"
        return
    fi

    echo "Preparing legal notice send with a dry-run preview..."
    local dry_run_response
    dry_run_response="$(request_send "$(build_payload "true")")"
    print_response "$dry_run_response"

    if command -v jq >/dev/null 2>&1; then
        local selected_count pending_count
        selected_count="$(echo "$dry_run_response" | jq -r '.selected_recipient_count // 0')"
        pending_count="$(echo "$dry_run_response" | jq -r '.pending_recipient_count // 0')"

        if [[ "$selected_count" == "0" || "$pending_count" == "0" ]]; then
            echo "No pending recipients selected for this run. Nothing will be sent."
            return
        fi
    fi

    if [[ "$confirm_send" != "true" ]]; then
        if [[ ! -t 0 ]]; then
            echo "Error: Refusing to send without --confirm in a non-interactive shell"
            exit 1
        fi

        echo ""
        echo "Type SEND to confirm legal notice email delivery:"
        local confirmation=""
        read -r confirmation
        if [[ "$confirmation" != "SEND" ]]; then
            echo "Send cancelled."
            exit 1
        fi
    fi

    echo "Sending legal notice emails..."
    print_response "$(request_send "$(build_payload "false")")"
}

cmd_publish_legal_doc() {
    local ingest_args=()
    local notify_args=()
    local confirm="false"
    local document_type=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --website-repo|--source-path|--commit|--version|--url|--effective-at|--blocking|--ack|--summary-json)
                ingest_args+=("$1" "${2:-}")
                shift 2
                ;;
            --document-type)
                document_type="${2:-}"
                ingest_args+=("$1" "${2:-}")
                shift 2
                ;;
            --confirm)
                confirm="true"
                shift
                ;;
            --limit)
                validate_positive_integer "${2:-}"
                notify_args+=("$1" "${2:-}")
                shift 2
                ;;
            --recipient-email)
                validate_email_arg "${2:-}"
                notify_args+=("$1" "${2:-}")
                shift 2
                ;;
            --recipient-id)
                validate_uuid "${2:-}"
                notify_args+=("$1" "${2:-}")
                shift 2
                ;;
            --api-url)
                notify_args+=("$1" "${2:-}")
                shift 2
                ;;
            --help|-h)
                cat <<EOF
Publish a legal document: ingest from a caution/website commit, activate it,
show a notice dry-run, and (with --confirm) email affected users.

Usage:
  ./utils/admin publish-legal-doc \\
    --website-repo /path/to/caution/website \\
    --document-type terms_of_service|privacy_notice \\
    --source-path terms.md|privacy.md \\
    --commit <sha> --version <display-version> \\
    --url <public-url> --effective-at YYYY-MM-DD [options]

Options:
  --blocking true|false     Override requires_blocking_reacceptance
  --ack true|false          Override requires_acknowledgment
  --summary-json <json>     Optional summary_json payload
  --confirm                 Send notice emails (default is dry-run only)
  --limit <n>               Cap recipients for this send
  --recipient-email <email> Scope send to a recipient (repeatable)
  --recipient-id <uuid>     Scope send to a recipient (repeatable)
  --api-url <url>           API base URL (default http://localhost:8080)

Without --confirm the document is still ingested and activated (users see the
modal immediately); only the email send is withheld pending --confirm.
EOF
                return 0
                ;;
            *)
                echo "Error: Unknown argument: $1"
                exit 1
                ;;
        esac
    done

    if [[ ${#ingest_args[@]} -eq 0 ]]; then
        echo "Error: missing ingest arguments; run 'publish-legal-doc --help'"
        exit 1
    fi

    echo "=== Step 1/2: ingest + activate ==="
    local ingest_output
    ingest_output="$("$SCRIPT_DIR/add-legal-doc-from-website.sh" "${ingest_args[@]}" --activate)"
    echo "$ingest_output"

    local doc_id
    doc_id="$(printf '%s\n' "$ingest_output" | awk -F': *' '/^[[:space:]]*id:/ {print $2; exit}')"
    if [[ -z "$doc_id" ]]; then
        echo "Error: could not determine inserted document id from ingest output"
        exit 1
    fi
    validate_uuid "$doc_id"

    echo ""
    echo "=== Step 2/2: notify (scoped to document $doc_id) ==="
    local send_args=("$doc_id")
    if [[ ${#notify_args[@]} -gt 0 ]]; then
        send_args+=("${notify_args[@]}")
    fi
    if [[ "$confirm" == "true" ]]; then
        send_args+=(--send --confirm)
    fi
    cmd_send_legal_notices "${send_args[@]}"

    if [[ "$confirm" != "true" ]]; then
        echo ""
        echo "Dry-run only. Re-run with --confirm to email affected users."
    fi
}

main() {
    local cmd="${1:-help}"
    shift || true

    case "$cmd" in
        help|--help|-h)
            cmd_help
            ;;
        list-orgs)
            cmd_list_orgs
            ;;
        show-org)
            [[ $# -lt 1 ]] && { echo "Error: Missing org ID"; exit 1; }
            cmd_show_org "$1"
            ;;
        list-users)
            cmd_list_users
            ;;
        show-user)
            [[ $# -lt 1 ]] && { echo "Error: Missing user ID"; exit 1; }
            cmd_show_user "$1"
            ;;
        list-apps)
            cmd_list_apps
            ;;
        show-app)
            [[ $# -lt 1 ]] && { echo "Error: Missing app ID"; exit 1; }
            cmd_show_app "$1"
            ;;
        list-credentials)
            cmd_list_credentials
            ;;
        list-alpha-codes)
            cmd_list_alpha_codes
            ;;
        user-by-code)
            [[ $# -lt 1 ]] && { echo "Error: Missing alpha code"; exit 1; }
            cmd_user_by_code "$1"
            ;;
        apps-by-user)
            [[ $# -lt 1 ]] && { echo "Error: Missing user ID"; exit 1; }
            cmd_apps_by_user "$1"
            ;;
        list-legal-docs)
            cmd_list_legal_docs
            ;;
        add-legal-doc)
            cmd_add_legal_doc
            ;;
        activate-legal-doc)
            [[ $# -lt 1 ]] && { echo "Error: Missing document ID"; exit 1; }
            cmd_activate_legal_doc "$1"
            ;;
        user-legal-status)
            [[ $# -lt 1 ]] && { echo "Error: Missing user ID"; exit 1; }
            cmd_user_legal_status "$1"
            ;;
        send-legal-notices)
            cmd_send_legal_notices "$@"
            ;;
        publish-legal-doc)
            cmd_publish_legal_doc "$@"
            ;;
        *)
            echo "Unknown command: $cmd"
            echo "Run './utils/admin help' for usage"
            exit 1
            ;;
    esac
}

main "$@"
